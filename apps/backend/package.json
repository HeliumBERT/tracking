{
  "name": "@repo/backend",
  "version": "0.1.0",
  "description": "Backend",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "migrate": "npx prisma migrate dev",
    "docker-up": "docker compose up -d",
    "docker-down": "docker compose down",
    "server": "node .",
    "all": "npm run docker-up server",
    "start": "ts-node -r tsconfig-paths/register src/index.ts",
    "test:migrate": "dotenv -e .env.test -- npx prisma migrate deploy",
    "test": "dotenv -e .env.test -- jest",
    "dev": "tsx watch src/index.ts",
    "prod:build": "tspc",
    "prod:start": "node ./out/src/index.js"
  },
  "keywords": [
    "backend"
  ],
  "author": "Azelynn Andrew Ritua",
  "license": "MIT",
  "dependencies": {
    "@repo/typescript-config": "workspace:*",
    "@absxn/process-env-parser": "^1.1.1",
    "@zodios/core": "^10.9.6",
    "argon2": "^0.44.0",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-async-errors": "^3.1.1",
    "express-list-routes": "^1.2.2",
    "express-openapi-validator": "^5.6.0",
    "express-rate-limit": "^8.2.1",
    "http-status-codes": "^2.3.0",
    "mime-types": "^3.0.1",
    "multer": "^2.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qs": "^6.12.3",
    "uint8-to-base64": "^0.2.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.3",
    "@types/supertest": "^6.0.3"
  }
}
