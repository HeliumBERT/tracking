{
  "extends": "@repo/typescript-config",
  "compilerOptions": {
    /* Visit https://aka.ms/tsconfig to read more about this file */

    // File Layout
    "rootDir": ".",
    "outDir": "./out",
    "paths": {
      "@src/*": ["./src/*"]
    }, 

    // Environment Settings
    "module": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "*.config.ts"
  ]
}
